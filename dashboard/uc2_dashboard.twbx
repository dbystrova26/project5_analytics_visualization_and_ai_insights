    <worksheet name='Lead Time Risk'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontsize='12'>Lead Time Risk</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='9'>The earlier the booking, the higher the risk. 365d+ bookings cancel at 68% vs 8% last-minute. Require deposits for &gt;90 day bookings.</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>The earlier the booking, the higher the risk. 365d+ bookings cancel at 68% vs 8% last-minute. Require deposits for &gt;90 day bookings.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='bookings_clean' name='federated.0t74gak1c5aeha19q6oia1f6zn0d' />
          </datasources>
          <datasource-dependencies datasource='federated.0t74gak1c5aeha19q6oia1f6zn0d'>
            <column caption='Cancellation Rate' datatype='real' name='[Calculation_0163011869417472]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([is_canceled]) / COUNT([is_canceled])' />
            </column>
            <column caption='Lead Time Bucket' datatype='string' name='[Calculation_0163011876159489]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [lead_time] &lt; 3 THEN &quot;0-2d&quot;&#13;&#10;ELSEIF [lead_time] &lt; 7 THEN &quot;3-6d&quot;&#13;&#10;ELSEIF [lead_time] &lt; 14 THEN &quot;7-13d&quot;&#13;&#10;ELSEIF [lead_time] &lt; 30 THEN &quot;14-29d&quot;&#13;&#10;ELSEIF [lead_time] &lt; 60 THEN &quot;30-59d&quot;&#13;&#10;ELSEIF [lead_time] &lt; 90 THEN &quot;60-89d&quot;&#13;&#10;ELSEIF [lead_time] &lt; 365 THEN &quot;90-364d&quot;&#13;&#10;ELSE &quot;365d+&quot;&#13;&#10;END' />
            </column>
            <column caption='Is Canceled' datatype='integer' name='[is_canceled]' role='measure' type='quantitative' />
            <column caption='Lead Time' datatype='integer' name='[lead_time]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0163011876159489]' derivation='None' name='[none:Calculation_0163011876159489:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0163011869417472]' derivation='User' name='[usr:Calculation_0163011869417472:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <shelf-sorts>
