<?xml version='1.0' encoding='utf-8' ?>
<workbook source-build='2023.1.0' source-platform='win' version='21.4' xmlns:user='http://www.tableausoftware.com/xml/user'>
  <preferences>
    <preference name='ui.encoding.shelf.height' value='24' />
    <preference name='ui.shelf.height' value='26' />
  </preferences>
  <datasources>
    <datasource caption='bookings_clean' inline='true' name='bookings_clean' version='21.4'>
      <connection class='textscan' filename='bookings_clean.csv' >
        <relation name='bookings_clean.csv' table='[bookings_clean.csv]' type='table' />
      </connection>
      <column caption='Hotel' datatype='string' name='[hotel]' role='dimension' type='nominal' />
      <column caption='Is Canceled' datatype='integer' name='[is_canceled]' role='measure' type='quantitative' />
      <column caption='Lead Time' datatype='integer' name='[lead_time]' role='measure' type='quantitative' />
      <column caption='Arrival Date Month' datatype='string' name='[arrival_date_month]' role='dimension' type='nominal' />
      <column caption='Market Segment' datatype='string' name='[market_segment]' role='dimension' type='nominal' />
      <column caption='Distribution Channel' datatype='string' name='[distribution_channel]' role='dimension' type='nominal' />
      <column caption='ADR' datatype='real' name='[adr]' role='measure' type='quantitative' />
      <column caption='Total Of Special Requests' datatype='integer' name='[total_of_special_requests]' role='measure' type='quantitative' />
      <column caption='Deposit Type' datatype='string' name='[deposit_type]' role='dimension' type='nominal' />
      <column caption='Customer Type' datatype='string' name='[customer_type]' role='dimension' type='nominal' />
      <column caption='Is Repeated Guest' datatype='integer' name='[is_repeated_guest]' role='dimension' type='nominal' />
      <column caption='Stays In Weekend Nights' datatype='integer' name='[stays_in_weekend_nights]' role='measure' type='quantitative' />
      <column caption='Stays In Week Nights' datatype='integer' name='[stays_in_week_nights]' role='measure' type='quantitative' />
      <column caption='Cancellation Rate' datatype='real' default-format='p1' name='[Cancellation Rate]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([is_canceled])/COUNT([is_canceled])' />
      </column>
      <column caption='Lead Time Bucket' datatype='string' name='[Lead Time Bucket]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [lead_time] &lt; 3 THEN &quot;1. 0-2d&quot; ELSEIF [lead_time] &lt; 7 THEN &quot;2. 3-6d&quot; ELSEIF [lead_time] &lt; 14 THEN &quot;3. 7-13d&quot; ELSEIF [lead_time] &lt; 30 THEN &quot;4. 14-29d&quot; ELSEIF [lead_time] &lt; 60 THEN &quot;5. 30-59d&quot; ELSEIF [lead_time] &lt; 90 THEN &quot;6. 60-89d&quot; ELSEIF [lead_time] &lt; 365 THEN &quot;7. 90-364d&quot; ELSE &quot;8. 365d+&quot; END' />
      </column>
      <column caption='Total Nights' datatype='integer' name='[Total Nights]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[stays_in_weekend_nights] + [stays_in_week_nights]' />
      </column>
      <layout dim-ordering='alphabetic' dim-percentage='0.5' measure-ordering='alphabetic' measure-percentage='0.4' show-structure='true' />
    </datasource>
  </datasources>

  <worksheets>
    <worksheet name='Cancellation by Channel'>
      <table>
        <view>
          <datasources>
            <datasource caption='bookings_clean' name='bookings_clean' />
          </datasources>
          <datasource-dependencies datasource='bookings_clean'>
            <column-instance column='[distribution_channel]' derivation='None' name='[none:distribution_channel:nk]' pivot='key' type='nominal' />
            <column-instance column='[Cancellation Rate]' derivation='None' name='[none:Cancellation Rate:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[bookings_clean].[distribution_channel]'>
            <groupfilter function='except' user:ui-marker='except'>
              <groupfilter function='union' user:ui-marker='union'>
                <groupfilter function='member' level='[distribution_channel]' member='&quot;Undefined&quot;' />
              </groupfilter>
            </groupfilter>
          </filter>
          <rows>[bookings_clean].[none:distribution_channel:nk]</rows>
          <cols>[bookings_clean].[none:Cancellation Rate:qk]</cols>
          <sort class='computed' column='[bookings_clean].[none:Cancellation Rate:qk]' direction='DESC' />
        </view>
        <style>
          <style-rule element='mark'>
            <encoding attr='type' value='bar' />
          </style-rule>
        </style>
        <panes>
          <pane>
            <mark class='Bar' />
            <axes>
              <axis column='[none:Cancellation Rate:qk]' rows='2'>
                <format attr='scale' field='[none:Cancellation Rate:qk]' value='p' />
              </axis>
            </axes>
          </pane>
        </panes>
      </table>
    </worksheet>

    <worksheet name='Lead Time Risk'>
      <table>
        <view>
          <datasources>
            <datasource caption='bookings_clean' name='bookings_clean' />
          </datasources>
          <datasource-dependencies datasource='bookings_clean'>
            <column-instance column='[Lead Time Bucket]' derivation='None' name='[none:Lead Time Bucket:nk]' pivot='key' type='nominal' />
            <column-instance column='[Cancellation Rate]' derivation='None' name='[none:Cancellation Rate:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <cols>[bookings_clean].[none:Lead Time Bucket:nk]</cols>
          <rows>[bookings_clean].[none:Cancellation Rate:qk]</rows>
        </view>
        <style>
          <style-rule element='mark'>
            <encoding attr='type' value='line' />
          </style-rule>
        </style>
        <panes>
          <pane>
            <mark class='Line' />
            <axes>
              <axis column='[none:Cancellation Rate:qk]' rows='2'>
                <format attr='scale' field='[none:Cancellation Rate:qk]' value='p' />
              </axis>
            </axes>
          </pane>
        </panes>
      </table>
    </worksheet>

    <worksheet name='Monthly Cancellation Trend'>
      <table>
        <view>
          <datasources>
            <datasource caption='bookings_clean' name='bookings_clean' />
          </datasources>
          <datasource-dependencies datasource='bookings_clean'>
            <column-instance column='[arrival_date_month]' derivation='None' name='[none:arrival_date_month:nk]' pivot='key' type='nominal' />
            <column-instance column='[Cancellation Rate]' derivation='None' name='[none:Cancellation Rate:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <cols>[bookings_clean].[none:arrival_date_month:nk]</cols>
          <rows>[bookings_clean].[none:Cancellation Rate:qk]</rows>
        </view>
        <style>
          <style-rule element='mark'>
            <encoding attr='type' value='bar' />
          </style-rule>
        </style>
        <panes>
          <pane>
            <mark class='Bar' />
            <axes>
              <axis column='[none:Cancellation Rate:qk]' rows='2'>
                <format attr='scale' field='[none:Cancellation Rate:qk]' value='p' />
              </axis>
            </axes>
          </pane>
        </panes>
      </table>
    </worksheet>

    <worksheet name='Special Requests Signal'>
      <table>
        <view>
          <datasources>
            <datasource caption='bookings_clean' name='bookings_clean' />
          </datasources>
          <datasource-dependencies datasource='bookings_clean'>
            <column-instance column='[total_of_special_requests]' derivation='None' name='[none:total_of_special_requests:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Cancellation Rate]' derivation='None' name='[none:Cancellation Rate:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <cols>[bookings_clean].[none:total_of_special_requests:ok]</cols>
          <rows>[bookings_clean].[none:Cancellation Rate:qk]</rows>
        </view>
        <style>
          <style-rule element='mark'>
            <encoding attr='type' value='bar' />
          </style-rule>
        </style>
        <panes>
          <pane>
            <mark class='Bar' />
            <axes>
              <axis column='[none:Cancellation Rate:qk]' rows='2'>
                <format attr='scale' field='[none:Cancellation Rate:qk]' value='p' />
              </axis>
            </axes>
          </pane>
        </panes>
      </table>
    </worksheet>

    <worksheet name='City vs Resort'>
      <table>
        <view>
          <datasources>
            <datasource caption='bookings_clean' name='bookings_clean' />
          </datasources>
          <datasource-dependencies datasource='bookings_clean'>
            <column-instance column='[hotel]' derivation='None' name='[none:hotel:nk]' pivot='key' type='nominal' />
            <column-instance column='[Cancellation Rate]' derivation='None' name='[none:Cancellation Rate:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <cols>[bookings_clean].[none:hotel:nk]</cols>
          <rows>[bookings_clean].[none:Cancellation Rate:qk]</rows>
        </view>
        <style>
          <style-rule element='mark'>
            <encoding attr='type' value='bar' />
          </style-rule>
        </style>
        <panes>
          <pane>
            <mark class='Bar' />
            <axes>
              <axis column='[none:Cancellation Rate:qk]' rows='2'>
                <format attr='scale' field='[none:Cancellation Rate:qk]' value='p' />
              </axis>
            </axes>
          </pane>
        </panes>
      </table>
    </worksheet>

    <worksheet name='Market Segment Risk'>
      <table>
        <view>
          <datasources>
            <datasource caption='bookings_clean' name='bookings_clean' />
          </datasources>
          <datasource-dependencies datasource='bookings_clean'>
            <column-instance column='[market_segment]' derivation='None' name='[none:market_segment:nk]' pivot='key' type='nominal' />
            <column-instance column='[Cancellation Rate]' derivation='None' name='[none:Cancellation Rate:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[bookings_clean].[market_segment]'>
            <groupfilter function='except' user:ui-marker='except'>
              <groupfilter function='union' user:ui-marker='union'>
                <groupfilter function='member' level='[market_segment]' member='&quot;Undefined&quot;' />
              </groupfilter>
            </groupfilter>
          </filter>
          <rows>[bookings_clean].[none:market_segment:nk]</rows>
          <cols>[bookings_clean].[none:Cancellation Rate:qk]</cols>
          <sort class='computed' column='[bookings_clean].[none:Cancellation Rate:qk]' direction='DESC' />
        </view>
        <style>
          <style-rule element='mark'>
            <encoding attr='type' value='bar' />
          </style-rule>
        </style>
        <panes>
          <pane>
            <mark class='Bar' />
            <axes>
              <axis column='[none:Cancellation Rate:qk]' rows='2'>
                <format attr='scale' field='[none:Cancellation Rate:qk]' value='p' />
              </axis>
            </axes>
          </pane>
        </panes>
      </table>
    </worksheet>
  </worksheets>

  <dashboards>
    <dashboard name='UC2 Cancellation Dashboard'>
      <style />
      <size maxheight='1200' maxwidth='1800' minheight='600' minwidth='800' />
      <zones>
        <zone h='98000' id='1' type='layout-flow' w='98000' x='1000' y='1000'>
          <zone h='49000' id='2' type='layout-flow' w='98000' x='1000' y='1000'>
            <zone h='49000' id='3' name='Cancellation by Channel' type='worksheet' w='32666' x='1000' y='1000' />
            <zone h='49000' id='4' name='Lead Time Risk' type='worksheet' w='32666' x='34666' y='1000' />
            <zone h='49000' id='5' name='Monthly Cancellation Trend' type='worksheet' w='32666' x='67332' y='1000' />
          </zone>
          <zone h='49000' id='6' type='layout-flow' w='98000' x='1000' y='50000'>
            <zone h='49000' id='7' name='Market Segment Risk' type='worksheet' w='32666' x='1000' y='50000' />
            <zone h='49000' id='8' name='Special Requests Signal' type='worksheet' w='32666' x='34666' y='50000' />
            <zone h='49000' id='9' name='City vs Resort' type='worksheet' w='32666' x='67332' y='50000' />
          </zone>
        </zone>
      </zones>
    </dashboard>
  </dashboards>
</workbook>
